# Copy this file to .env and fill in real values.
# .env is already in .gitignore — never commit your actual .env file.

# Generate a new one anytime with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-real-generated-secret-key

# Set to True only on your local machine, never in production
DJANGO_DEBUG=True

# Comma-separated list, e.g. localhost,127.0.0.1,yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1